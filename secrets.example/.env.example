DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=your_db_host
DB_PORT=3306
DB_NAME=your_db_name
# 단일 연결 문자열을 쓰는 환경에서는 위 DB_* 대신 DATABASE_URL을 사용할 수 있습니다.
# DATABASE_URL=sqlite:///local.db
FLASK_SECRET_KEY=your_flask_secret_key_here
APP_ENV=development
# 로컬 단일 프로세스는 all, 운영은 web/worker/scheduler 프로세스로 분리합니다.
APP_PROCESS_ROLE=all
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here
SESSION_COOKIE_SECURE=false
SOCKETIO_CORS_ORIGINS=http://127.0.0.1:9200
PUBLIC_BASE_URL=http://127.0.0.1:9200

# 비밀번호 재설정 메일
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=no-reply@example.com
SMTP_USE_TLS=true

# AI 작업 큐 및 동영상 샘플링
AI_MAX_WORKERS=1
AI_MAX_PENDING_JOBS=10
AI_JOB_RETRIES=1
AI_JOB_STALE_SECONDS=900
AI_VIDEO_SAMPLE_FPS=2
YOLO_MODEL_PATH=C:/absolute/path/to/best.pt
# certutil -hashfile best.pt SHA256 결과
YOLO_MODEL_SHA256=your_trusted_model_sha256
REQUIRE_AI_MODEL=false
REQUIRE_KAKAO_KEYS=false
REQUIRE_PROFANITY_FILTER=false
REQUIRE_SMTP=false
PRIVACY_BLUR_ENABLED=true
VIDEO_GPS_OCR_ENABLED=true
RETENTION_SCHEDULER_ENABLED=true
DELETED_MEDIA_RETENTION_DAYS=7
REJECTED_MEDIA_RETENTION_DAYS=30
LOCATION_RETENTION_DAYS=365
AI_JOB_RETENTION_DAYS=30
ORPHAN_UPLOAD_RETENTION_HOURS=24
RETENTION_INTERVAL_SECONDS=86400
# BACKUP_DIRECTORY=C:/secure/backups/crack
# MYSQLDUMP_PATH=C:/Program Files/MySQL/MySQL Server 8.0/bin/mysqldump.exe
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=30
LOG_LEVEL=INFO
# LOG_FILE=logs/crack.json.log

# 전체 DB 복사 도구(대상 DB의 기존 테이블을 교체하므로 실행할 때만 설정)
# DB_COPY_SOURCE=source_database
# DB_COPY_TARGET=target_database
# CONFIRM_DATABASE_REPLACE=REPLACE:target_database
